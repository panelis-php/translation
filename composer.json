{
  "name": "panelis-php/translation",
  "description": "Manage application translations directly from the admin panel",
  "license": "MIT",
  "keywords": [
    "panelis"
  ],
  "require": {
    "lorisleiva/laravel-actions": "^2.10",
    "illuminate/support": "^13.0",
    "filament/filament": "^5.0"
  },
  "autoload": {
    "psr-4": {
      "Panelis\\Translation\\": "src/",
      "Panelis\\Translation\\Database\\Factories\\": "database/factories/",
      "Panelis\\Translation\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Panelis\\Translation\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Panelis\\Translation\\Providers\\TranslationServiceProvider"
      ]
    },
    "panelis": {
      "plugins": [
        "Panelis\\Translation\\Plugins\\TranslationPlugin"
      ]
    }
  }
}
